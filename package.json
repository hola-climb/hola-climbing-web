{
  "name": "ola",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "copy:ffmpeg": "mkdir -p public/ffmpeg && cp node_modules/@ffmpeg/core/dist/esm/ffmpeg-core.js node_modules/@ffmpeg/core/dist/esm/ffmpeg-core.wasm public/ffmpeg/",
    "predev": "npm run copy:ffmpeg",
    "dev": "vite",
    "prebuild": "npm run copy:ffmpeg",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test:e2e": "cypress run",
    "test:unit": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "@capacitor/app": "8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "8.0.2",
    "@capacitor/ios": "^8.4.0",
    "@capacitor/keyboard": "8.0.3",
    "@capacitor/status-bar": "8.0.2",
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@grafana/faro-web-sdk": "^2.7.1",
    "@grafana/faro-web-tracing": "^2.7.1",
    "@ionic/vue": "^8.0.0",
    "@ionic/vue-router": "^8.0.0",
    "@stomp/stompjs": "^7.3.0",
    "axios": "^1.16.1",
    "ionicons": "^7.0.0",
    "pinia": "^3.0.4",
    "vite-plugin-pwa": "^1.3.0",
    "vue": "^3.3.0",
    "vue-router": "^4.6.4",
    "workbox-precaching": "^7.4.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@vitejs/plugin-legacy": "^5.0.0",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.3.0",
    "axios-mock-adapter": "^2.1.0",
    "cypress": "^13.5.0",
    "eslint": "^8.35.0",
    "eslint-plugin-vue": "^9.9.0",
    "jsdom": "^22.1.0",
    "terser": "^5.4.0",
    "typescript": "~5.9.0",
    "vite": "^5.0.0",
    "vitest": "^0.34.6",
    "vue-tsc": "^2.1.10"
  },
  "description": "An Ionic project"
}
